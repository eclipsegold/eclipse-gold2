{%- liquid
  assign title = section.settings.title | default: page.title
  assign body = section.settings.body
-%}

<section class="egp">
  <div class="egp-inner">
    <h1 class="egp-title">{{ title }}</h1>
    <div class="egp-body">{{ body }}</div>
  </div>
</section>

{% stylesheet %}
  .egp {
    background: #000000;
    color: #f5f1e8;
    padding: 120px 24px 100px;
    min-height: 70vh;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
    box-sizing: border-box;
  }
  .egp-inner {
    max-width: 820px;
    margin: 0 auto;
  }
  .egp-title {
    font-family: 'Didot', 'Bodoni 72', 'Playfair Display', Georgia, serif;
    color: #d4af37;
    font-size: clamp(32px, 4vw, 48px);
    letter-spacing: 8px;
    text-transform: uppercase;
    font-weight: 400;
    margin: 0 0 56px;
    text-align: center;
    line-height: 1.2;
  }
  .egp-body {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    color: #f5f1e8;
    font-size: 15px;
    line-height: 1.85;
    font-weight: 300;
    opacity: 0.9;
  }
  .egp-body h2 {
    font-family: 'Didot', 'Bodoni 72', 'Playfair Display', Georgia, serif;
    color: #d4af37;
    font-size: 22px;
    letter-spacing: 4px;
    text-transform: uppercase;
    font-weight: 400;
    margin: 48px 0 18px;
  }
  .egp-body h3 {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    color: #d4af37;
    font-size: 14px;
    letter-spacing: 3px;
    text-transform: uppercase;
    font-weight: 500;
    margin: 32px 0 12px;
  }
  .egp-body p { margin: 0 0 16px; }
  .egp-body a {
    color: #d4af37;
    text-decoration: underline;
    text-underline-offset: 4px;
  }
  .egp-body ul, .egp-body ol {
    padding-left: 24px;
    margin: 0 0 20px;
  }
  .egp-body li { margin-bottom: 8px; }
  .egp-body strong { color: #f5f1e8; font-weight: 500; }
  @media (max-width: 749px) {
    .egp { padding: 80px 20px 60px; }
    .egp-title { letter-spacing: 4px; margin-bottom: 36px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Eclipse Gold Policy",
  "tag": "section",
  "settings": [
    { "type": "text",     "id": "title", "label": "Titre" },
    { "type": "richtext", "id": "body",  "label": "Contenu", "default": "<p>Contenu de la page.</p>" }
  ],
  "presets": [
    { "name": "Eclipse Gold Policy", "category": "Eclipse Gold" }
  ]
}
{% endschema %}

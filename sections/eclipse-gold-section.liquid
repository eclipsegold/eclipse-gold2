{% comment %}
==========================================
  SECTION : Eclipse Gold Collection v3
  OBSERVATY — design ultra premium épuré
==========================================
{% endcomment %}

<section class="eg-section">
  <div class="eg-container">

    <div class="eg-header">
      <p class="eg-subtitle">{{ section.settings.subtitle }}</p>
      <h2 class="eg-title">{{ section.settings.title }}</h2>
      <p class="eg-tagline">{{ section.settings.tagline }}</p>
    </div>

    {%- assign coll = section.settings.collection -%}

    {% if coll.products.size > 0 %}

      {%- assign hero1 = section.settings.hero_product_1 -%}
      {%- assign hero2 = section.settings.hero_product_2 -%}

      {% if hero1 != blank or hero2 != blank %}
        <div class="eg-grid-heroes">
          {% if hero1 != blank %}
            {% render 'eclipse-gold-card', product: hero1, is_hero: true, badge_type: 'bestseller' %}
          {% endif %}
          {% if hero2 != blank %}
            {% render 'eclipse-gold-card', product: hero2, is_hero: true, badge_type: 'limited' %}
          {% endif %}
        </div>
      {% endif %}

      {%- assign hero1_handle = hero1.handle | default: '' -%}
      {%- assign hero2_handle = hero2.handle | default: '' -%}
      {%- assign others_count = 0 -%}

      <div class="eg-grid-collection eg-grid-top">
        {% for product in coll.products limit: 50 %}
          {% if product.handle != hero1_handle and product.handle != hero2_handle %}
            {%- assign others_count = others_count | plus: 1 -%}
            {% if others_count <= 4 %}
              {% render 'eclipse-gold-card', product: product, is_hero: false, badge_type: '' %}
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>

      {%- assign others_count = 0 -%}
      <div class="eg-grid-collection eg-grid-bottom">
        {% for product in coll.products limit: 50 %}
          {% if product.handle != hero1_handle and product.handle != hero2_handle %}
            {%- assign others_count = others_count | plus: 1 -%}
            {% if others_count > 4 and others_count <= 8 %}
              {% render 'eclipse-gold-card', product: product, is_hero: false, badge_type: '' %}
            {% endif %}
          {% endif %}
        {% endfor %}
      </div>

      {%- if section.settings.show_cta and section.settings.cta_label != blank -%}
        <div class="eg-discover">
          <a class="eg-discover-link" href="{{ section.settings.cta_link | default: '/collections/les-10-eclats' }}">
            {{ section.settings.cta_label | escape }}
          </a>
        </div>
      {%- endif -%}

    {% else %}
      <p class="eg-empty">Aucun produit dans cette collection.</p>
    {% endif %}

  </div>
</section>

<style>
  .eg-section {
    background-color: #000000;
    color: #f5f1e8;
    padding: 120px 24px;
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    width: 100%;
    max-width: 100vw;
    overflow-x: hidden;
  }
  .eg-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  /* HEADER */
  .eg-header {
    text-align: center;
    margin-bottom: 80px;
  }
  .eg-subtitle {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 11px;
    letter-spacing: 6px;
    text-transform: uppercase;
    color: #d4af37;
    opacity: 0.6;
    margin: 0 0 24px;
    font-weight: 500;
  }
  .eg-title {
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 5vw, 56px);
    letter-spacing: 12px;
    text-transform: uppercase;
    color: #d4af37;
    margin: 0 0 24px;
    font-weight: 400;
    line-height: 1.1;
  }
  .eg-tagline {
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-style: italic;
    font-size: 16px;
    color: #f5f1e8;
    opacity: 0.7;
    margin: 0;
    letter-spacing: 0.5px;
  }

  /* GRIDS */
  .eg-section .eg-grid-heroes {
    display: grid !important;
    grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
    gap: 48px;
    margin: 0 auto 64px;
    width: 100%;
    max-width: 70%;
  }
  .eg-section .eg-grid-collection {
    display: grid !important;
    grid-template-columns: repeat(4, minmax(0, 1fr)) !important;
    gap: 48px;
    width: 100%;
  }
  .eg-grid-bottom { margin-top: 64px; }

  /* CARDS — minimal, transparent, no border */
  .eg-card {
    background: transparent;
    border: none;
    border-radius: 0;
    overflow: hidden;
    box-shadow: none;
    transition: none;
    position: relative;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    width: 100%;
    max-width: 100%;
    min-width: 0;
  }
  .eg-card * { min-width: 0; max-width: 100%; }
  .eg-card .eg-btn { white-space: normal; }
  .eg-card:hover {
    border: none;
    transform: none;
    box-shadow: none;
  }
  .eg-card--hero {
    border: none;
  }
  .eg-card--hero:hover {
    border: none;
    transform: none;
    box-shadow: none;
  }
  .eg-card.is-sold-out { opacity: 1; }

  /* BADGES — minimal, top-left, gold bar above text */
  .eg-badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: transparent;
    color: #d4af37;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 10px;
    letter-spacing: 3px;
    text-transform: lowercase;
    padding: 0;
    border-radius: 0;
    z-index: 2;
    font-weight: 500;
    line-height: 1;
  }
  .eg-badge::before {
    content: "";
    display: block;
    width: 20px;
    height: 1px;
    background: #d4af37;
    margin-bottom: 8px;
  }
  .eg-badge--bestseller {
    background: transparent;
    color: #d4af37;
  }
  .eg-card--hero .eg-badge {
    top: 18px;
    left: 18px;
    font-size: 11px;
    letter-spacing: 3.5px;
  }

  /* IMAGE — fills card, soft zoom on hover */
  .eg-image-wrap {
    aspect-ratio: 1 / 1;
    background-color: #0a0a0a;
    overflow: hidden;
    position: relative;
    display: block;
  }
  .eg-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms ease;
  }
  .eg-card:hover .eg-image {
    transform: scale(1.05);
  }
  .eg-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0a0a0a;
    color: #d4af37;
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 18px;
    letter-spacing: 6px;
    text-transform: uppercase;
    opacity: 0.5;
    padding: 16px;
    text-align: center;
  }

  /* INFO — name + price */
  .eg-info {
    padding: 24px 0 0;
    text-align: left;
    text-decoration: none;
    color: inherit;
    display: block;
  }
  .eg-name {
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 14px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #d4af37;
    font-weight: 400;
    margin: 0 0 8px;
    line-height: 1.3;
    overflow-wrap: break-word;
    word-break: break-word;
    min-width: 0;
  }
  .eg-card {
    min-width: 0;
  }
  .eg-card--hero .eg-name {
    font-size: 18px;
    letter-spacing: 5px;
  }
  .eg-price {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-weight: 300;
    font-size: 13px;
    color: #f5f1e8;
    opacity: 0.7;
    margin: 0 0 16px;
    letter-spacing: 0.5px;
  }

  /* BUTTON — underline only, no box */
  .eg-action {
    padding: 0;
    margin-top: 0;
    text-align: left;
  }
  .eg-form { margin: 0; display: inline-block; }
  .eg-btn {
    background: transparent;
    color: #d4af37;
    border: none;
    border-bottom: 1px solid #d4af37;
    padding: 4px 0;
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 11px;
    letter-spacing: 3px;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 360ms ease, color 360ms ease, padding 360ms ease;
    font-weight: 400;
    line-height: 1.4;
    display: inline-block;
  }
  .eg-btn:hover:not(:disabled) {
    background: #d4af37;
    color: #000000;
    padding: 4px 14px;
    border-bottom-color: #d4af37;
  }
  .eg-btn--waitlist {
    background: transparent;
    color: rgba(212, 175, 55, 0.55);
    border-bottom-color: rgba(212, 175, 55, 0.35);
    cursor: not-allowed;
  }

  /* DISCOVER — section-level CTA */
  .eg-discover {
    text-align: center;
    margin-top: 80px;
  }
  .eg-discover-link {
    display: inline-block;
    font-family: 'Didot', 'Bodoni MT', 'Playfair Display', Georgia, serif;
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #d4af37;
    text-decoration: none;
    padding: 6px 0;
    border-bottom: 0.5px solid rgba(212, 175, 55, 0.5);
    transition: border-bottom-color 360ms ease;
  }
  .eg-discover-link:hover {
    border-bottom-color: #d4af37;
  }

  /* EMPTY */
  .eg-empty {
    text-align: center;
    color: #d4af37;
    opacity: 0.6;
  }

  /* MOBILE */
  @media (max-width: 749px) {
    .eg-section { padding: 80px 20px; }
    .eg-header { margin-bottom: 56px; }
    .eg-title {
      font-size: clamp(28px, 8vw, 40px);
      letter-spacing: 6px;
    }
    .eg-subtitle { letter-spacing: 4px; }
    .eg-section .eg-grid-heroes {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 24px;
      max-width: 100%;
      margin-bottom: 56px;
    }
    .eg-section .eg-grid-collection {
      grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
      gap: 24px;
    }
    .eg-grid-bottom { margin-top: 56px; }
    .eg-discover { margin-top: 56px; }
    .eg-card--hero .eg-name { font-size: 16px; letter-spacing: 4px; }
    .eg-name { font-size: 13px; letter-spacing: 3px; }
    .eg-info { padding-top: 18px; }
  }
</style>

{% schema %}
{
  "name": "Eclipse Gold Collection",
  "tag": "section",
  "class": "section-eclipse-gold",
  "settings": [
    {
      "type": "header",
      "content": "Contenu de l'en-tête"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sous-titre",
      "default": "Collection signature"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Titre principal",
      "default": "LES 10 ÉCLATS"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Dix phénomènes du ciel. Dix paires d'exception."
    },
    {
      "type": "header",
      "content": "Collection à afficher"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection complète (10 produits)"
    },
    {
      "type": "header",
      "content": "Best-sellers (2 cartes en haut)"
    },
    {
      "type": "product",
      "id": "hero_product_1",
      "label": "Best-seller #1 (gauche) — ex: TOTALIS"
    },
    {
      "type": "product",
      "id": "hero_product_2",
      "label": "Best-seller #2 (droite) — ex: HELIOS"
    },
    {
      "type": "header",
      "content": "CTA en bas de section"
    },
    {
      "type": "checkbox",
      "id": "show_cta",
      "label": "Afficher le bouton Découvrir",
      "default": true
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Texte du bouton",
      "default": "DÉCOUVRIR LA COLLECTION COMPLÈTE"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Lien du bouton"
    }
  ],
  "presets": [
    {
      "name": "Eclipse Gold Collection"
    }
  ]
}
{% endschema %}

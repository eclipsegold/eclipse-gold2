# Absolute base URL for canonical/sitemap (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://eclipsegold.com

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Order notifications (Resend — free). Optional: if unset, orders are logged
# in the function logs instead of emailed.
RESEND_API_KEY=re_xxx
ORDER_NOTIFICATION_EMAIL=you@example.com
# Optional sender. Defaults to onboarding@resend.dev (works without a verified
# domain, but can only deliver to the Resend account owner's address).
ORDER_FROM_EMAIL=Eclipse Gold <onboarding@resend.dev>
